DAO_TREASURY_ADDRESS=
DAO_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs
DAO_NONCE_TTL_SECONDS=300
DAO_DEFAULT_QUORUM_BPS=2000
MODERATION_ENABLED=true
MODERATION_REVIEW_HOURS=24
MODERATION_TOXICITY_THRESHOLD=0.55
MODERATION_SPAM_THRESHOLD=0.65
MODERATION_FAKE_NEWS_THRESHOLD=0.70
MODERATION_AI_GENERATED_THRESHOLD=0.85
MODERATION_PLAGIARISM_THRESHOLD=0.80
MODERATION_BOT_RISK_THRESHOLD=0.70
MODERATION_AUTHENTICITY_MIN_THRESHOLD=0.35
SERVER_PORT=8080

# OTP delivery providers:
# Email providers: console | resend
# SMS providers: console | textbelt
OTP_BRAND_NAME=Lulit
OTP_EMAIL_PROVIDER=resend
OTP_SMS_PROVIDER=console

# Resend email API (free tier available)
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@yourdomain.com

# Textbelt SMS API
# WARNING: The free "textbelt" key supports only 1 SMS per day.
# For production, purchase a key at https://textbelt.com
TEXTBELT_URL=https://textbelt.com/text
TEXTBELT_API_KEY=textbelt

# Spring profiles: set to "prod" for production (enforces ddl-auto=validate, secure cookies)
# SPRING_PROFILES_ACTIVE=prod

# Log level for com.lulit.backend package
LOG_LEVEL=INFO
