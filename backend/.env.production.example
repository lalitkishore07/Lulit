SPRING_PROFILES_ACTIVE=prod
DB_URL=jdbc:postgresql://YOUR_DB_HOST:5432/lulit
DB_USERNAME=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
HIBERNATE_DDL_AUTO=validate
AES_KEY=REPLACE_WITH_32_CHAR_SECRET
JWT_SECRET_BASE64=REPLACE_WITH_LONG_BASE64_SECRET
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
CORS_ORIGIN=https://app.yourdomain.com,https://www.yourdomain.com
COOKIE_SECURE=true
OAUTH2_SUCCESS_REDIRECT_URI=https://app.yourdomain.com/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
PINATA_JWT=
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs
BLOCKCHAIN_ENABLED=true
BLOCKCHAIN_RPC_URL=https://YOUR_CHAIN_RPC
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_CONTRACT_ADDRESS=
DAO_ENABLED=true
DAO_RPC_URL=https://YOUR_CHAIN_RPC
DAO_TOKEN_ADDRESS=0xYOUR_TOKEN_ADDRESS
DAO_GOVERNANCE_ADDRESS=0xYOUR_GOVERNANCE_ADDRESS
DAO_TREASURY_ADDRESS=0xYOUR_TREASURY_ADDRESS
DAO_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs
DAO_NONCE_TTL_SECONDS=300
DAO_DEFAULT_QUORUM_BPS=2000
MODERATION_ENABLED=true
AI_ENABLED=true
AI_EMBEDDING_ENDPOINT=https://ai.yourdomain.com/embedding
AI_MODERATION_ENDPOINT=https://ai.yourdomain.com/moderation
AI_SUMMARY_ENDPOINT=https://ai.yourdomain.com/summary
OTP_BRAND_NAME=Lulit
OTP_EMAIL_PROVIDER=resend
OTP_SMS_PROVIDER=textbelt
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@yourdomain.com
TEXTBELT_URL=https://textbelt.com/text
TEXTBELT_API_KEY=
SERVER_PORT=8080
LOG_LEVEL=INFO
