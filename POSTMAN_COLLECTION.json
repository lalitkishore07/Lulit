{
  "info": {
    "name": "Lulit API",
    "_postman_id": "f8fd73e8-a9e0-47a5-a2a3-96ce10e2ed56",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Signup Email OTP Request",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/auth/signup/email/request",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\"\n}" }
      }
    },
    {
      "name": "Signup Email OTP Verify",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/auth/signup/email/verify",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\"\n}" }
      }
    },
    {
      "name": "Signup Phone OTP Request",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/auth/signup/phone/request",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"countryCode\": \"+91\",\n  \"phoneNumber\": \"9876543210\"\n}" }
      }
    },
    {
      "name": "Signup Phone OTP Verify",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/auth/signup/phone/verify",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"123456\"\n}" }
      }
    },
    {
      "name": "Signup Aadhaar Verify",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/auth/signup/aadhaar/verify",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"aadhaarNumber\": \"123456789012\"\n}" }
      }
    },
    {
      "name": "Signup Complete",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/auth/signup/complete",
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"username\": \"testuser\",\n  \"password\": \"Test@1234\"\n}" }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/auth/login",
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"Test@1234\"\n}" }
      }
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/auth/refresh"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" }
  ]
}
